# Staging / soft-launch environment for Railway + Neon + Vercel
# Copy values into Railway service variables (do not commit real secrets)

DJANGO_SETTINGS_MODULE=jobsp.settings_staging
DEBUG=False
SECRET_KEY=change-me-to-a-random-secret

# Neon PostgreSQL (Dashboard → Connection string, prefer pooler + sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Backend public URL (Railway)
PEEL_URL=https://api-production-e35c.up.railway.app/
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,api-production-e35c.up.railway.app

# Frontend URLs (Vercel)
SITE_FRONTEND_URL=https://job-irk.vercel.app
RECRUITER_FRONTEND_URL=https://job-irk-recruiter.vercel.app

# Auth cookies (managed by SvelteKit frontends via same-origin /api/v1 proxy)
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=Lax

# Soft launch: true (no SMTP needed). Full public launch: false + real EMAIL_BACKEND
AUTO_VERIFY_EMAIL=true

# Simplified search (no Elasticsearch on staging)
HAYSTACK_ENGINE=haystack.backends.simple_backend.SimpleEngine

DEFAULT_FROM_EMAIL=Truddy <noreply@truddy.ru>

# --- Hard production upgrades (optional; enable when ready) ---
# EMAIL_BACKEND=django_ses.SESBackend
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
# AWS_SES_REGION_NAME=eu-central-1
# AWS_SES_REGION_ENDPOINT=email.eu-central-1.amazonaws.com
# AWS_STORAGE_BUCKET_NAME=truddy-media
# AWS_ENABLED=true
# MEDIA_STORAGE=s3
