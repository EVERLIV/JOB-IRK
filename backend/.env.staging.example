# Staging environment for Railway + Neon
# Copy to Railway service variables

DJANGO_SETTINGS_MODULE=jobsp.settings_staging
DEBUG=False
SECRET_KEY=change-me-to-a-random-secret

# Neon PostgreSQL connection string (Dashboard → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Or individual DB vars (if not using DATABASE_URL):
# DB_NAME=neondb
# DB_USER=user
# DB_PASSWORD=password
# DB_HOST=ep-xxx.region.aws.neon.tech
# DB_PORT=5432

# Backend public URL (Railway generated domain)
PEEL_URL=https://your-api.up.railway.app/
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,your-api.up.railway.app

# Frontend URLs (Vercel generated domains — set after deploying frontends)
SITE_FRONTEND_URL=https://your-site.vercel.app
RECRUITER_FRONTEND_URL=https://your-recruiter.vercel.app

# Auth cookies managed by SvelteKit frontends on staging
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=Lax

# Auto-activate accounts on staging (no email server required)
AUTO_VERIFY_EMAIL=true

# Simplified search (no Elasticsearch)
HAYSTACK_ENGINE=haystack.backends.simple_backend.SimpleEngine

DEFAULT_FROM_EMAIL=PeelJobs <noreply@peeljobs.local>
