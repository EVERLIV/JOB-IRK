# Hard-production Railway overrides (paste into Railway variables when leaving soft launch)
# Do not commit real secrets. Soft launch keeps AUTO_VERIFY_EMAIL=true and console email.

AUTO_VERIFY_EMAIL=false

EMAIL_BACKEND=django_ses.SESBackend
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_SES_REGION_NAME=eu-central-1
AWS_SES_REGION_ENDPOINT=email.eu-central-1.amazonaws.com
DEFAULT_FROM_EMAIL=Truddy <noreply@your-verified-domain>

MEDIA_STORAGE=s3
AWS_ENABLED=true
AWS_STORAGE_BUCKET_NAME=

# Keep DEBUG=false; AUTH_COOKIE_SECURE=true
